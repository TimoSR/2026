{
  "version": 4,
  "configurations": [
    {
      "name": "Win64-Clang",
      "intelliSenseMode": "windows-clang-x64",
      "compilerPath": "C:/Program Files/LLVM/bin/clang++.exe",
      "cStandard": "c17",
      "cppStandard": "c++20",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/src"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/include",
          "${workspaceFolder}/src"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}

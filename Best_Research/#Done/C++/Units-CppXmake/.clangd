Index:
  Background: Build

Diagnostics:
  UnusedIncludes: Strict
  MissingIncludes: None
  Suppress:
    # clangd false positives from MSVC STL <format> while importing C++20 modules.
    - ovl_ambiguous_init
    - ovl_no_viable_function_in_call

Completion:
  HeaderInsertion: Never

---
If:
  PathMatch: .*Physics\.cppm

CompileFlags:
  Add:
    - -x
    - c++-module
    - -std=c++23

Diagnostics:
  UnusedIncludes: None

---
If:
  PathMatch: .*aztro_physics[\\/].*tests\.cpp|.*aztro_physics[\\/]tests[\\/]main\.cpp

CompileFlags:
  Add:
    - -I.

---
If:
  PathMatch: .*aztro_physics[\\/].+[\\/].*\.cppm

CompileFlags:
  Add:
    - -std=c++23
    - -include
    - aztro_physics/fragment_prelude.cppm

Diagnostics:
  UnusedIncludes: None

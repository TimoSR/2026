# Convenience commands for the xmake workflow.
set dotenv-load
set shell := ["pwsh.exe", "-NoLogo", "-Command"]
set quiet

xmake_debug_config := "xmake f -m debug"
clangd_compile_database := "xmake project -k compile_commands --lsp=clangd ."
cmake_project_dir := "."
visual_studio_project_dir := "."

_default:
    just --list --unsorted
    #just --summary
    #just --list
alias f1 := setup
# Install just completions for PowerShell.
# Configure the debug target and generate clangd's project-root compilation database.
[doc]
setup:
    just --completions powershell | Out-String | Set-Content -Encoding UTF8 $PROFILE
    {{ xmake_debug_config }}
    xmake
    xmake build AztroPhysicsTests
    {{ clangd_compile_database }}
# Dependency example: `just all` runs step1, then step2, then step3.
[doc]
all: step1 step2 step3 step4

solution_gen: cmake vs

step1:
    {{ xmake_debug_config }}
step2:
    xmake
step3:
    xmake build AztroPhysicsTests
step4:
    {{ clangd_compile_database }}
build: all

cmake:
    xmake project -k cmake {{ cmake_project_dir }}

vs:
    xmake project -k vsxmake -m "debug,release" -a x64 {{ visual_studio_project_dir }}

run: all
    xmake run PhysicsDemo
test: all
    Write-Host "No root tests configured."
test-physics:
    xmake f -P physics -m debug
    xmake run -P physics PhysicsTests
test-aztro-physics:
    xmake f -P aztro_physics -m debug
    xmake run -P aztro_physics AztroPhysicsTests
format:
    Get-ChildItem -Path physics,aztro_physics,Testing,src -Recurse -Include *.hpp,*.cpp,*.cppm | ForEach-Object { clang-format -i $_.FullName }
release:
    xmake f -m release
    xmake
    xmake project -k compile_commands --lsp=clangd .
flamegraph: run
    python scripts/render_flamegraph.py
flamechart: run
    python scripts/render_flamechart.py
samply: release
    samply record build/windows/x64/release/PhysicsDemo.exe

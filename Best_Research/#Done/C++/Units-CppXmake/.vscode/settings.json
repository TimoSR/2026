{
  "editor.formatOnSave": true,
  "files.associations": {
    "*.S": "asm",
    "*.cppm": "cpp",
    "*.ixx": "cpp",
    "*.mpp": "cpp",
    "*.mxx": "cpp"
  },
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.formatting": "disabled",
  "C_Cpp.codeAnalysis.runAutomatically": false,
  "C_Cpp.errorSquiggles": "disabled",
  "C_Cpp.autocomplete": "disabled",
  "xmake.compileCommandsBackend": "clangd",
  "xmake.autoGenerateCompileCommands": "onFileChange",
  "xmake.compileCommandsDirectory": ".vscode",
  "xmake.enableSyntaxCheck": false,
  "clangd.path": "C:\\Program Files\\Microsoft Visual Studio\\18\\Community\\VC\\Tools\\Llvm\\x64\\bin\\clangd.exe",
  "clangd.arguments": [
    "--experimental-modules-support"
  ],
  "[cpp]": {
    "editor.inlayHints.enabled": "on",
    "editor.formatOnSave": true
  }
}

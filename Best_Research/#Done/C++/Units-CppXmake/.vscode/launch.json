{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug C++ (CodeLLDB)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/linux/x86_64/debug/assembly_subroutines",
      "windows": {
        "program": "${workspaceFolder}/build/windows/x64/debug/assembly_subroutines.exe"
      },
      "osx": {
        "program": "${workspaceFolder}/build/macosx/arm64/debug/assembly_subroutines"
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated",
      "preLaunchTask": "xmake build (debug)"
    },
    {
      "name": "Debug C++ (MSVC -- Windows only)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/windows/x64/debug/assembly_subroutines.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "preLaunchTask": "xmake build (debug)"
    }
  ]
}

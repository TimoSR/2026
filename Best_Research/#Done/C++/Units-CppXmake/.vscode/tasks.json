{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xmake configure (debug)",
      "type": "shell",
      "command": "xmake",
      "args": [
        "f",
        "-m",
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "xmake build aztro_physics_tests (debug)",
      "type": "shell",
      "command": "xmake",
      "args": [
        "build",
        "aztro_physics_tests"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "xmake configure (debug)",
      "problemMatcher": [
        "$msCompile",
        "$gcc"
      ]
    },
    {
      "label": "xmake compile database (clangd)",
      "type": "shell",
      "command": "xmake",
      "args": [
        "project",
        "-k",
        "compile_commands",
        "--lsp=clangd",
        "."
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOrder": "sequence",
      "dependsOn": [
        "xmake build all (debug)",
        "xmake build aztro_physics_tests (debug)"
      ],
      "problemMatcher": []
    },
    {
      "label": "xmake build all (debug)",
      "type": "shell",
      "command": "xmake",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "xmake configure (debug)",
      "problemMatcher": [
        "$msCompile",
        "$gcc"
      ]
    },
    {
      "label": "xmake run physics_demo",
      "type": "shell",
      "command": "xmake",
      "args": [
        "run",
        "physics_demo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "xmake build all (debug)",
      "problemMatcher": [
        "$msCompile",
        "$gcc"
      ]
    },
    {
      "label": "just test physics",
      "type": "shell",
      "command": "just",
      "args": [
        "test-physics"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile",
        "$gcc"
      ]
    },
    {
      "label": "just test aztro_physics",
      "type": "shell",
      "command": "just",
      "args": [
        "test-aztro-physics"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile",
        "$gcc"
      ]
    }
  ]
}

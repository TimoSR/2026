# Convenience commands for the physics library xmake workflow.
set dotenv-load
set shell := ["pwsh.exe", "-NoLogo", "-Command"]
set quiet

xmake_debug_config := "xmake f -P . -m debug"

_default:
    just --list --unsorted

setup:
    {{ xmake_debug_config }}

all: setup build

build:
    {{ xmake_debug_config }}
    xmake -P .

test:
    {{ xmake_debug_config }}
    xmake run -P . PhysicsTests

format:
    Get-ChildItem -Path . -Recurse -Include *.hpp,*.cpp | ForEach-Object { clang-format -i $_.FullName }

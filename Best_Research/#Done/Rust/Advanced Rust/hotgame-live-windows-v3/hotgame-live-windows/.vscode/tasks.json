{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "hotgame: doctor",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\doctor.ps1"
      ],
      "problemMatcher": "$rustc"
    },
    {
      "label": "hotgame: run",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\run.ps1"
      ],
      "problemMatcher": "$rustc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "hotgame: check",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\check.ps1"
      ],
      "problemMatcher": "$rustc"
    }
  ]
}

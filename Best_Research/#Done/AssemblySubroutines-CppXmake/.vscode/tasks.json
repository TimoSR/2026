{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xmake configure (debug)",
      "type": "shell",
      "command": "xmake",
      "args": [
        "f",
        "-m",
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "xmake compile database (clangd)",
      "type": "shell",
      "command": "xmake",
      "args": [
        "project",
        "-k",
        "compile_commands",
        "--lsp=clangd",
        "."
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "xmake configure (debug)",
      "problemMatcher": []
    },
    {
      "label": "xmake build (debug)",
      "type": "shell",
      "command": "xmake",
      "args": [
        "build",
        "assembly_subroutines"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "xmake compile database (clangd)",
      "problemMatcher": [
        "$msCompile",
        "$gcc"
      ]
    }
  ]
}

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Rust (CodeLLDB — Windows, macOS, Linux)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "build",
          "--bin=io_macros_project"
        ],
        "filter": {
          "name": "io_macros_project",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated"
    },
    {
      "name": "Debug Rust (MSVC — Windows only)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/target/debug/io_macros_project.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "preLaunchTask": "cargo build (debug)"
    }
  ]
}
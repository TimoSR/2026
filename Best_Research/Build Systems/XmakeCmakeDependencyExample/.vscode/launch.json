{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: xmake CMake consumer (Clang)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/windows/x64/debug/xmake_cmake_consumer.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
